{
    "info": {
        "_postman_id": "b2d8cc64-b97c-4d5e-a2f2-avid-users",
        "name": "Avid Panel - User Module API",
        "description": "Postman collection for testing Avid User Module APIs.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:4000/api/v1",
            "type": "string"
        },
        {
            "key": "userId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Service - Base API Status",
            "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}"
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 200', function () {",
                            "  pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test('Response is JSON', function () {",
                            "  pm.response.to.be.json;",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Users - Get Metadata",
            "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/users/meta/options"
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 200', function () {",
                            "  pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test('Metadata exists', function () {",
                            "  const json = pm.response.json();",
                            "  pm.expect(json.success).to.eql(true);",
                            "  pm.expect(json.data.roles).to.be.an('array');",
                            "  pm.expect(json.data.statuses).to.be.an('array');",
                            "  pm.expect(json.data.accessLevels).to.be.an('array');",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Users - Create Employee",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "url": "{{baseUrl}}/users",
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"firstName\": \"علی\",\n  \"lastName\": \"احمدی\",\n  \"email\": \"ali.ahmadi.{{$timestamp}}@avid.local\",\n  \"phone\": \"09120000000\",\n  \"password\": \"StrongPass123!\",\n  \"role\": \"EMPLOYEE\",\n  \"profile\": {\n    \"jobTitle\": \"توسعه‌دهنده فرانت‌اند\",\n    \"domain\": \"توسعه نرم‌افزار\",\n    \"specialtyChapter\": \"Frontend\",\n    \"responsibilityScope\": \"پیاده‌سازی رابط کاربری پنل مدیریتی\"\n  },\n  \"workUnit\": {\n    \"isIndependentWorkUnit\": true,\n    \"unitCode\": \"DEV-FE-{{$timestamp}}\",\n    \"responsibilities\": [\n      \"ثبت گزارش روزانه\",\n      \"ارائه شواهد برای خروجی‌های انجام‌شده\",\n      \"هماهنگی با مالک پروژه در موارد وابستگی\"\n    ],\n    \"limits\": [\n      \"عدم تغییر محدوده پروژه بدون تایید مدیریت\"\n    ],\n    \"defaultReportRequired\": true\n  }\n}"
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Status code is 201', function () {",
                            "  pm.response.to.have.status(201);",
                            "});",
                            "",
                            "pm.test('Created user id is saved', function () {",
                            "  const json = pm.response.json();",
                            "  pm.expect(json.success).to.eql(true);",
                            "  pm.expect(json.data.id).to.be.a('string');",
                            "  pm.collectionVariables.set('userId', json.data.id);",
                            "});",
                            "",
                            "pm.test('Password hash is not returned', function () {",
                            "  const json = pm.response.json();",
                            "  pm.expect(json.data.passwordHash).to.be.undefined;",
                            "});"
                        ]
                    }
                }
            ]
        },
